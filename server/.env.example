# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/devlog
# For MongoDB Atlas (production):
# MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/devlog?retryWrites=true&w=majority

# JWT Secret (use a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# CORS Configuration
CLIENT_URL=http://localhost:5173
# For production:
# CLIENT_URL=https://your-frontend-domain.com

# ===== V2 Configuration =====

# Resend Email Service (for notifications)
# Get your API key from https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=DevLog <notifications@yourdomain.com>

# Cron Secret (protect serverless cron endpoints)
# Generate a random string: openssl rand -hex 32
CRON_SECRET=your-cron-secret-key-change-this

# Note: Admin access is now role-based. To make a user admin:
# 1. Open MongoDB shell or Atlas
# 2. Run: db.users.updateOne({email: "admin@example.com"}, {$set: {role: "admin"}})
