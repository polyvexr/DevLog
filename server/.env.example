# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/devlog
# For MongoDB Atlas (production):
# MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/devlog?retryWrites=true&w=majority

# JWT Secret (use a strong random string)
# Generate: openssl rand -hex 64
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# CORS Configuration
CLIENT_URL=http://localhost:5173
CORS_ALLOW_CREDENTIALS=true
# For production:
# CLIENT_URL=https://your-frontend-domain.com

# ===== V2 Configuration =====

# GitHub API Token (strongly recommended to avoid rate limits)
# Increases rate limit from 60/hr to 5000/hr
# Create at https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Resend Email Service (for password resets)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=DevLog <onboarding@resend.dev>

# Cron Secret (protect serverless cron endpoints)
# Required in production. Generate: openssl rand -hex 32
CRON_SECRET=your-cron-secret-key-change-this

# CList API (for contest data)
CLIST_API_KEY=username:api_key

# Telegram Bot (for system alerts - optional)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Logging
# levels: error, warn, info, debug
LOG_LEVEL=info

# Admin
ADMIN_EMAIL=admin@example.com

# ===== Notes =====

# Admin access is now role-based. To make a user admin:
# Option 1: Use the script:
#   node scripts/makeAdmin.js admin@example.com
#
# Option 2: Direct database update:
#   db.users.updateOne({email: "admin@example.com"}, {$set: {role: "admin"}})
