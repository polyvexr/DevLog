# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/devlog
# For MongoDB Atlas (production):
# MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/devlog?retryWrites=true&w=majority

# JWT Secret (use a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Admin Configuration
# The email address that will have admin privileges
ADMIN_EMAIL=admin@devlog.com

# CORS Configuration
CLIENT_ORIGIN=http://localhost:5173
# For production (Vercel/Netlify):
# CLIENT_ORIGIN=https://your-frontend-domain.com

CORS_ALLOW_CREDENTIALS=true
